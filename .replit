modules = ["nodejs-24", "python-3.11"]

[[ports]]
localPort = 23220
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 3000

[[ports]]
localPort = 8081
externalPort = 3001

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[objectStorage]
defaultBucketID = "replit-objstore-912a51f7-edf2-45f2-9100-46108da9a586"

[userenv]

[userenv.shared]
HYPERFX_MCP_URL = "https://backend.hyperfx.ai/mcp/"
